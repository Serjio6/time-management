NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/flowstate
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative: paste the full service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=24h

# Encryption (32+ char random string; used to derive an AES-256 key)
ENCRYPTION_KEY=change_this_to_a_long_random_string

# Client
CLIENT_URL=http://localhost:5173

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=support@flowstate.app

# Google Calendar sync (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

LOG_LEVEL=info
